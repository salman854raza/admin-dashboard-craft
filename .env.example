# Public (safe to expose to browser) — Vite requires the VITE_ prefix
VITE_SUPABASE_URL=https://utllswqajudzehlfwryv.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SERVER-ONLY — used only inside /api serverless functions, never bundled to the browser.
# Do NOT prefix with VITE_. Get this from Supabase Dashboard > Project Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_URL=https://utllswqajudzehlfwryv.supabase.co

# Email of the single admin account (used by the promote-admin setup script)
ADMIN_EMAIL=you@example.com
